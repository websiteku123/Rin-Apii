{
  "version": 2,
  "functions": {
    "index.js": {
      "memory": 3009,
      "maxDuration": 30
    }
  },
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/index.js"
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "API_KEY": "Rinn",
    "API_CREATOR": "Rin imup"
  }
}
